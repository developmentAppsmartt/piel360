{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @piel360/api run build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @piel360/api run migrate:deploy && pnpm --filter @piel360/api run start:prod",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
