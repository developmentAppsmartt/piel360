# Copiar a .env para desarrollo. En Railway se configuran como variables del servicio
# (DATABASE_URL/REDIS_URL las inyectan automáticamente los plugins de Postgres/Redis).
#
# Requeridas al boot (la API no arranca sin ellas — usan config.getOrThrow):
#   DATABASE_URL, REDIS_URL, JWT_SECRET, JWT_REFRESH_SECRET, FRONTEND_URL,
#   ENCRYPTION_KEY, SKINIVER_API_URL, SKINIVER_API_TOKEN,
#   S3_BUCKET, S3_ACCESS_KEY, S3_SECRET_KEY, YOUCAM_API_URL, YOUCAM_API_KEY
# Opcionales (tienen fallback si faltan):
#   RESEND_API_KEY, MAIL_FROM, GOOGLE_CLIENT_ID/SECRET/REDIRECT_URI,
#   S3_ENDPOINT, YOUCAM_WEBHOOK_SECRET
#
# Las credenciales de Wompi NO van acá — se parametrizan en producción vía el
# CRUD de /admin/gateway-configs (tabla gateway_configs), no como env var.

DATABASE_URL=
REDIS_URL=
PORT=
FRONTEND_URL=

JWT_SECRET=
JWT_REFRESH_SECRET=

ENCRYPTION_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_MAPS_API_KEY=

YOUCAM_API_URL=
YOUCAM_API_KEY=
# Webhook registrado en el dashboard de Perfect Corp: https://<tu-dominio>/webhooks/youcam
YOUCAM_WEBHOOK_SECRET=

SKINIVER_API_URL=
SKINIVER_API_TOKEN=

S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

RESEND_API_KEY=
MAIL_FROM=
