# URL base de la API Nest (incluye el prefijo /api).
#
# Puedes dejar localhost: en Android/dispositivo Expo Go la app la reescribe
# automáticamente a la IP del packager (la misma de exp://IP:8081) o a 10.0.2.2.
#
# Forzar IP LAN (opcional):
#   EXPO_PUBLIC_API_URL=http://192.168.100.236:3000/api
#
# Tras cambiar este archivo: reinicia Metro con `pnpm start -c`.
EXPO_PUBLIC_API_URL=http://localhost:3000/api
